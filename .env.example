TELEGRAM_BOT_TOKEN=replace-with-botfather-token

# Required in Vercel Project Settings > Environment Variables.
# Keep the real API key out of this file and out of Git.
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# Optional: use https://openrouter.ai/api with an OpenRouter key/model.
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Comma-separated private Telegram chat IDs that receive the daily report.
TELEGRAM_DAILY_CHAT_IDS=-1001234567890
TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890
DAILY_UPDATE_TIME=08:00

# Vercel webhook, cron, and Postgres configuration.
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
CRON_SECRET=replace-with-a-random-cron-secret
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
PUBLIC_BASE_URL=https://your-project.vercel.app
